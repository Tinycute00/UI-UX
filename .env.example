# =============================================================================
# Ta Chen PMIS — Frontend 環境變數範本
# =============================================================================
# 複製此檔為 .env.local，填入實際值（.env.local 不應提交到 git）
# 
# 最後更新：2026-04-14
# 參考文件：docs/devops-readiness-v1.md section 7.1

# API 連線設定
VITE_API_BASE_URL=http://localhost:3000/api

# 環境識別（development / staging / production）
VITE_APP_ENV=development

# =============================================================================
# [staging] 請取消下方註解並設定 staging URL
# VITE_API_BASE_URL=https://staging-api.pmis.example.com/api
# VITE_APP_ENV=staging
# =============================================================================

# =============================================================================
# [production] 請取消下方註解並設定 production URL
# VITE_API_BASE_URL=https://api.pmis.example.com/api
# VITE_APP_ENV=production
# =============================================================================