# ============================================================================
# 公共工程甲級營造廠工務所前端管理系統 — 環境變數
# ============================================================================

# Supabase（必填）
# 取得方式：Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only（勿以 NEXT_PUBLIC_ 開頭）
# 僅供 API Route / Server Action 使用，絕對不可暴露給瀏覽器
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 應用程式
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=公共工程工務所管理系統

# Feature flags
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_OFFLINE_QUEUE=true
