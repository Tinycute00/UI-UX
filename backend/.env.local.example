# Backend 環境變數範本 — 本地開發 (OPS-306)
# ============================================================
# 複製此檔為 .env.local 後填入（.env.local 不應 commit 到 git）
# DEV-ONLY: 以下密碼僅供本地驗證，不可用於 staging / production
# ============================================================

# PostgreSQL 連線字串（對應 docker-compose.yml postgres service）
DATABASE_URL=postgresql://pmis:pmis_dev_pw@localhost:5432/pmis_dev

# 應用設定
NODE_ENV=development
PORT=3000

# JWT 密鑰（本地 dev 用，production 請換成強隨機值）
JWT_SECRET=local_dev_secret_replace_in_production
JWT_REFRESH_SECRET=local_refresh_secret_replace_in_production
