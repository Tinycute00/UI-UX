# ─────────────────────────────────────────────
# Ta Chen PMIS Backend — 環境變數設定
# ─────────────────────────────────────────────
# 使用方式：複製此檔案為 .env 並填入實際值
#   cp .env.example .env

# ─── Server ───────────────────────────────────
# HTTP 伺服器監聽端口
PORT=3000

# 執行環境（development | production | test）
NODE_ENV=development

# ─── Database ─────────────────────────────────
# PostgreSQL 連線字串（待 database role 完成後替換為實際值）
# 格式：postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://localhost:5432/tachenpmis

# ─── JWT 認證 ─────────────────────────────────
# JWT 簽名密鑰（生產環境必須使用強隨機字串，至少 32 字元）
# 產生方式：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=dev-secret-key-at-least-32-characters-long!

# Access Token 有效期（分鐘）
JWT_ACCESS_EXPIRES_MINUTES=15

# Refresh Token 有效期（天）
JWT_REFRESH_EXPIRES_DAYS=7

# ─── CORS ─────────────────────────────────────
# 允許的 CORS 來源
# "*" = 允許所有來源（開發環境用）
# 多個來源用逗號分隔，例：http://localhost:5173,https://pmis.example.com
CORS_ORIGIN=*
